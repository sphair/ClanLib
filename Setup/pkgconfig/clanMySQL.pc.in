# pkg-config Metadata for clanMySQL

prefix=@prefix@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include/ClanLib-@LT_RELEASE@

Name: clanMySQL
Description: MySQL support for ClanLib
Version: @VERSION@
Requires: clanDatabase-@LT_RELEASE@ = @VERSION@
Libs:   -L${libdir} -lclanMySQL @extra_LIBS_clanMySQL@
Cflags: -I${includedir} @extra_CFLAGS_clanMySQL@

# EOF #