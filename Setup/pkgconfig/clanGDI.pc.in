# pkg-config Metadata for clanGDI

prefix=@prefix@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include/ClanLib-@LT_RELEASE@

Name: clanGDI
Description: portable main() wrapper of ClanLib
Version: @VERSION@
Requires: clanDisplay-@LT_RELEASE@ = @VERSION@
Libs:   -L${libdir} -lclanGDI @extra_LIBS_clanGDI@
Cflags: -I${includedir} @extra_CFLAGS_clanGDI@

# EOF #
